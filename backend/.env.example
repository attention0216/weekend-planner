# .env 模板 — 复制为 .env 并填入真实值
# cp .env.example .env

# 高德地图 Web服务 API Key（申请：https://console.amap.com）
AMAP_KEY=

# Claude API Key（申请：https://console.anthropic.com）
CLAUDE_API_KEY=

# DeepSeek API Key（申请：https://platform.deepseek.com）
DEEPSEEK_API_KEY=

# Tavily 搜索 API Key（申请：https://tavily.com）
TAVILY_API_KEY=

# RSSHub 实例地址（可用公共实例或自部署）
RSSHUB_BASE=https://rsshub.app

# 城市配置
CITY_NAME=北京
DOUBAN_CITY_ID=108288

# 聚合间隔（小时）
AGGREGATION_INTERVAL_HOURS=6
