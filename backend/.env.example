# .env 模板 — 复制为 .env 并填入真实值
# cp .env.example .env

# LLM API（OpenAI 兼容格式）
LLM_API_KEY=
LLM_BASE_URL=https://llm.listenhub.dev/v1
LLM_MODEL=claude-opus-4-6

# 高德地图 Web服务 API Key（可选，申请：https://console.amap.com）
AMAP_KEY=

# Tavily 搜索 API Key（可选，用于小红书餐厅推荐，申请：https://tavily.com）
TAVILY_API_KEY=

# 城市配置
CITY_NAME=北京

# 聚合间隔（小时）
AGGREGATION_INTERVAL_HOURS=6
